# Longbox environment template — copy to .env for local dev,
# or set these in the Portainer stack's environment editor.
# Phase 1 reads none of these; they land in later phases.

APP_ENV=production
DATA_DIR=/data

# Metadata sources — all optional; app degrades gracefully if unset.
# ISBN flow:    Metron + Open Library (in parallel, Metron first).
# Issue-ID flow: ComicVine + Metron  (in parallel, ComicVine first).

# COMICVINE_API_KEY=
# COMICVINE_USER_AGENT=Longbox/0.1 (+https://your-host)

# METRON_USER=
# METRON_PASS=

# Cache TTL for upstream metadata responses (default 30 days).
# METADATA_CACHE_TTL_DAYS=30

# Hardening (recommended when exposing Longbox beyond localhost).
# Both are no-ops while unset; defaults match the LAN-only model.
#
# Comma-separated TrustedHostMiddleware allowlist. `*` accepts any
# Host header (default). Tighten when fronted by a reverse proxy.
# ALLOWED_HOSTS=longbox.lan,localhost
#
# Comma-separated CSRF origin allowlist. When set, any non-GET POST
# whose `Origin` header isn't on this list gets rejected with 403 —
# blocks a malicious site from POSTing to /admin/wipe etc. via your
# browser. Leave empty to disable. List the exact URLs you actually
# open Longbox at (scheme + host + port, no trailing slash).
# CSRF_ALLOWED_ORIGINS=http://longbox.lan:8080,https://longbox.lan
